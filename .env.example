# BIA-OS environment variables
# Copy this file to .env and fill in your values.
# NEVER commit .env — it is in .gitignore.

# ── Reddit API (required for Reddit collector) ─────────────────────────────
# Free credentials: https://www.reddit.com/prefs/apps → create app → type: script
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here

# ── Database location (optional — defaults to backend/data/bia.db) ─────────
# BIA_DATA_DIR=/absolute/path/to/data/directory

# ── API server (optional — defaults shown) ────────────────────────────────
# BIA_HOST=127.0.0.1
# BIA_PORT=8000

# ── Collector limits (optional — conservative defaults shown) ─────────────
# HN_STORY_LIMIT=80
# REDDIT_POST_LIMIT=25
