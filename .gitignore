# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
*.egg-info/
dist/
build/
.eggs/

# ── Environment and secrets ────────────────────────────────────────────────
# NEVER commit credentials or API keys
.env
.env.*
!.env.example
secrets.json
credentials.json

# ── Database ───────────────────────────────────────────────────────────────
# The database is runtime state, not source code.
# Each environment (local, CI, production) builds its own from collected data.
backend/data/*.db
backend/data/*.db-shm
backend/data/*.db-wal

# ── OS and editor files ────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
*.code-workspace

# ── Test and coverage artifacts ────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── Logs ──────────────────────────────────────────────────────────────────
*.log
logs/

# ── Jupyter (if ever used for analysis) ───────────────────────────────────
.ipynb_checkpoints/
